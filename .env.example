# OpenAI API Key（从 https://platform.openai.com/api-keys 获取）
# 或使用兼容的 API 代理服务（如 OpenRouter、lingkeapi 等）
OPENAI_API_KEY=your_api_key_here

# API Base URL（可选，默认为 OpenAI 官方 API）
# 如果使用代理服务，请填写对应的 endpoint
# 示例：https://api.openai.com/v1、https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# 音频分析模型（推荐使用支持音频输入的模型）
# 示例：gpt-4o-audio-preview、gemini-2.5-flash、gemini-2.5-pro
AUDIO_MODEL_NAME=gpt-4o-audio-preview

# REAPER 脚本超时时间（可选，单位：毫秒，默认 10000）
REAPER_SCRIPT_TIMEOUT=10000